# DeepSeek V3 API 密钥
DEEPSEEK_API_KEY=

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# PostgreSQL 连接串（格式：postgresql://user:password@host:port/dbname）
DATABASE_URL=

# 企业微信企业ID
WECHAT_CORP_ID=

# 企业微信应用AgentId
WECHAT_AGENT_ID=

# 企业微信应用Secret
WECHAT_SECRET=

# 企业微信回调Token（用于验证回调请求来源）
WECHAT_TOKEN=

# 企业微信回调EncodingAESKey（用于解密回调消息）
WECHAT_ENCODING_AES_KEY=

# Boss直聘登录态文件存放路径
STORAGE_STATES_DIR=./storage_states

# Boss直聘 CDP 连接地址（生产环境用 connect_over_cdp 连接已登录的浏览器）
CDP_ENDPOINT=

# 日志级别
LOG_LEVEL=INFO

# 复制此文件为 .env.local 并填入实际值，.env.local 不提交到 Git
